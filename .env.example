# Copia este archivo a `.env` y rellena los valores si quieres que n8n-MCP
# tenga acceso a tu instancia de n8n (modo "management", no solo docs).
#
# Si no defines estas variables, n8n-MCP se instala en modo "solo documentación".

# URL pública de tu instancia n8n (sin trailing slash)
N8N_API_URL=https://tu-instancia-n8n.com

# API key generada desde Settings -> API en n8n
N8N_API_KEY=tu-api-key-aqui
